{% extends "layout.twig" %}

{% block content %}
    <h2>Candidatures </h2>

    <h3>Société: {{ meta.entreprise }}</h3>
    <h3>Offre: {{ meta.titre }}</h3>
    <h4>Description: {{ meta.description }}</h4>
    <h4>Date offre: {{ meta.date_offre }}</h4>
    <h4>Base de rémunération: {{ meta.base_remuneration }} €/mois</h4>
    

    <div class="results">
        {% if results is not empty %}
            {% for candidature in results %}
                
                <div class="card">
                    <div class="card-left">
                        <h3>
                            {{candidature.candidat_nom }} {{candidature.candidat_prenom }}
                        </h3>
                        <div class="card">
                            <div class="card-right">
                            <p><u>Email</u>: {{candidature.candidat_email }}</p>
                            </div>
                            <div class="card-right">
                                <p><u>Date candidature</u>: {{candidature.date_postule }}</p>
                            </div> 
                            <div class="card-right">
                                <!-- Modif User -->
                                {{ candidature.buttons.edit|raw }}

                                <!-- Modif Candidature -->
                                {{ candidature.buttons.postule|raw }}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}

        {% if totalPages > 1 %}
            <div class="pagination">
            {% for p in pagination %}
                {% if p == '...' %}
                    <span class="pagination-dots">...</span>
                {% else %}
                    <form method="POST" style="display:inline;">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <input type="hidden" name="page" value="{{ p }}">
                        <button type="submit"
                                class="page-btn {{ p == page ? 'active' : '' }}">
                            {{ p }}
                        </button>
                    </form>
                {% endif %}
            {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}