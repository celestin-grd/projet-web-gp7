{% extends "layout.twig" %}

{% block content %}
    <h2>Création d'entreprise </h2>

    {# 🔴 erreurs #}
    {% if errors is not empty %}
        <div class="error-box">
            {% for fieldErrors in errors %}
                {% for error in fieldErrors %}
                    <p>{{ error }}</p>
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    <form id="formEntreprise" data-validate="true" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <label for="nom">Nom</label>
        <input type="text" id="nom" name="nom" value="{{ filters.nom }}" data-validate="required|alpha">

        <label for="description">Description</label>
        <textarea name="description" id="description" data-validate="required|txt|min:10">{{ filters.description }}</textarea>

        <label for="telephone">Téléphone</label>
        <input type="text" id="telephone" name="telephone" value="{{ filters.telephone }}" data-validate="required|phone">

        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="{{ filters.email }}" data-validate="required|email">

        <label> Active
            <input type="checkbox"
                name="valide"
                value="1"
                {% if filters.valide is not defined or filters.valide %}checked{% endif %}
                >
        </label>

        <button type="submit">Sauve</button>
        <button type="button" onclick="window.location.href='{{ CDN ~ PREFIX }}/entreprise/recherche'">Annule</button>

    </form>
{% endblock %}
