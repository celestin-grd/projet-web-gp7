{% extends "layout.twig" %}

{% block content %}

    <h2>Recherche d'entreprises </h2>

    <p>A la recherche d'une entreprise pour alternance ou pour un stage</p>

    {# 🔴 erreurs #}
    {% if errors is not empty %}
        <div class="error-box">
            {% for fieldErrors in errors %}
                {% for error in fieldErrors %}
                    <p>{{ error }}</p>
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    {# 🔎 FORMULAIRE SIMPLE #}
    <form method="POST">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="page" value="{{ page|default(1) }}">
        <input type="hidden" name="valide" value="{{ filters.valide ? 1 : 0 }}">

        <div class="search-box">
            <input type="text"
                name="nom"
                placeholder="Nom de l'entreprise"
                value="{{ filters.nom|default('') }}">
            <button type="submit">Rechercher</button>
        </div>
    </form>

    <div class="search-advanced">
        <button type="button" id="btnAffiner">Affiner</button>
    </div>

    {# 📦 RESULTATS #}
    <div class="results">

    {% if results is not empty %}

        {% for entreprise in results %}
            <div class="card">

                <div class="card-left">
                    <h3>{{ entreprise.nom }}</h3>
                    <p>{{ entreprise.description }}</p>
                    <p><u>Email</u>: {{ entreprise.email }}</p>
                    <p><u>Téléphone</u>: {{ entreprise.telephone }}</p>
                    </p>
                </div>
                <div class="card-left">
                    {% if entreprise.offres > 0 %}
                        <p><u>Offres</u>: (<a class="btn-icon"
                                    href="{{ CDN ~ PREFIX }}/offre/show/{{ entreprise.id_entreprise }}">
                                    {{ entreprise.offres }}
                                </a>)
                        </p>
                    {% endif %}
                </div>
                <div class="card-right">
                    <div class="stars-rating"
                        data-value="{{ entreprise.eval_stars }}"
                        data-readonly="true">

                        {% for i in 1..5 %}
                            <span data-value="{{ i }}">☆</span>
                        {% endfor %}

                        {% if entreprise.eval_stars %}
                            moy: {{ entreprise.eval_moyenne }}
                            (<a class="btn-icon"
                                href="{{ CDN ~ PREFIX }}/evaluation/show/{{ entreprise.id_entreprise }}">
                                {{ entreprise.eval_nbre }}
                            </a>)
                        {% endif %}
                    </div>
                </div>

                <div class="card-right">

                    {# ⭐ Evaluate #}
                    {% if not entreprise.in_evaluate %}
                        {{ entreprise.buttons.evaluate|raw }}
                    {% endif %}

                    {# ✏️ Edit #}
                    {{ entreprise.buttons.edit|raw }}

                    {# 🗑 Delete #}
                    {{ entreprise.buttons.delete|raw }}

                </div>
            </div>
        {% endfor %}

    {% else %}
        <div class="card">
            <h3>Aucun résultat</h3>
        </div>
    {% endif %}

    {# 📄 PAGINATION #}
    {% if totalPages > 1 %}
        <div class="pagination">

            {% for p in pagination %}

                {% if p == '...' %}
                    <span class="pagination-dots">...</span>
                {% else %}
                    <form method="POST" style="display:inline;">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <input type="hidden" name="page" value="{{ p }}">

                        <input type="hidden" name="nom" value="{{ filters.nom|default('') }}">
                        <input type="hidden" name="description" value="{{ filters.description|default('') }}">
                        <input type="hidden" name="telephone" value="{{ filters.telephone|default('') }}">
                        <input type="hidden" name="email" value="{{ filters.email|default('') }}">
                        <input type="hidden" name="valide" value="{{ filters.valide ? 1 : 0 }}">

                        <button type="submit"
                                class="page-btn {{ p == page ? 'active' : '' }}">
                            {{ p }}
                        </button>
                    </form>
                {% endif %}

            {% endfor %}
        </div>
    {% endif %}

    </div>

    <button class="btn-add"
            onclick="window.location.href='{{ CDN ~ PREFIX }}/entreprise/create'">
        Ajouter
    </button>

    {# 🧠 MODAL #}
    <div class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>

            <h3>Recherche avancée</h3>

            <form method="POST">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="page" value="{{ page|default(1) }}">

                <label>Description</label>
                <input type="text"
                    name="description"
                    data-validate="optional|txt"
                    value="{{ filters.description|default('') }}">

                <label>Téléphone</label>
                <input type="text"
                    name="telephone"
                    data-validate="optional|phone"
                    value="{{ filters.telephone|default('') }}">

                <label>Email</label>
                <input type="email"
                    name="email"
                    data-validate="optional|email"
                    value="{{ filters.email|default('') }}">

                <label>
                    Active
                    <input type="checkbox"
                        name="valide"
                        value="1"
                        {% if filters.valide is not defined or filters.valide %}checked{% endif %}>
                </label>

                <button type="submit">Rechercher</button>
            </form>
        </div>
    </div>

{% endblock %}