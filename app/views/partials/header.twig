<header class="header">
    <div class="logo">
        <img src="{{ STATIQUE ~ PREFIX }}/app-icons/C.png" alt="LOGO" width="80" height="60">
    </div>

    <h1 class="title">{{ APP_NAME }}</h1>

    <div class="burger">☰</div>

    <nav class="nav">
        <ul>
            {% for menu, items in menus %}
                {% if menu is not empty %}
                    <li class="menu-group">
                        <span>{{ menu }}</span>
                        <ul>
                            {% for item in items %}

                                {# gestion login/logout #}
                                {% if item.label == 'Login' and isLogged %}
                                    {# ne rien afficher #}

                                {% elseif item.label == 'Logout' and not isLogged %}
                                    {# ne rien afficher #}

                                {% else %}
                                    <li>
                                        <a href="{{ CDN ~ PREFIX ~ item.url }}">
                                            {{ item.label }}
                                        </a>
                                    </li>
                                {% endif %}

                            {% endfor %}
                        </ul>
                    </li>
                {% endif %}
            {% endfor %}
        </ul>
    </nav>
</header>

{% if isLogged %}
    <div class="thincard">
        <p class="role">
            {{ user.nom ~ ' ' ~ user.prenom }} ({{ user.role }})
        </p>
    </div>
{% endif %}